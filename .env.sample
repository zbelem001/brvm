# sample environment variables for docker-compose
# copy to .env and edit before starting

# postgres connection settings (cloud or local)
# the migration script now distinguishes between a *local* database and the Neon
# target. local settings use the LOCAL_DB_* prefix; the Neon URL is passed as an
# argument to the script or you can set DATABASE_URL for your backend.

# local Postgres server (used for dumping)
# you can either specify the components individually or one URL:
#LOCAL_DB_HOST=127.0.0.1
#LOCAL_DB_PORT=5432
#LOCAL_DB_USER=postgres
#LOCAL_DB_PASS=changeme  # optionally used by pg_dump
#LOCAL_DB_NAME=brvm
# or
#LOCAL_DB_URL=postgres://postgres:changeme@127.0.0.1:5432/brvm

# Neon connection string (destination) – not used by backend unless you set DATABASE_URL
#NEON_URL=postgresql://neondb_owner:npg_8lb9hskSXynH@ep-billowing-dust-abbl4wli-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# for the backend itself you may still want DATABASE_URL instead of the LOCAL_ vars
#DATABASE_URL=postgresql://user:pass@host:port/dbname

# uncomment and fill the appropriate values for your workflow
