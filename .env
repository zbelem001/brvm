# sample environment variables for docker-compose
# copy to .env and edit before starting

# postgres connection settings (cloud or local)
# you can either provide individual parts or a full URL.
# when using Neon the easiest is to set DATABASE_URL directly,
# otherwise fill DB_HOST/DB_PORT/DB_USER/DB_PASS/DB_NAME separately.

# example with separate values (local Postgres):
#DB_HOST=127.0.0.1
#DB_PORT=5432
#DB_USER=postgres
#DB_PASS=changeme
#DB_NAME=brvm

# example using a Neon connection string:
#DATABASE_URL=postgresql://neondb_owner:npg_8lb9hskSXynH@ep-billowing-dust-abbl4wli-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# uncomment and edit one of the above before starting

# utilisation de la chaîne complète Neon
#DB_HOST=ep-billowing-dust-abbl4wli-pooler.eu-west-2.aws.neon.tech
#DB_PORT=5432
#DB_USER=neondb_owner
#DB_PASS=npg_8lb9hskSXynH
#DB_NAME=neondb

# local Postgres for migration
#DB_HOST=127.0.0.1
#DB_PORT=5432
#DB_USER=postgres
#DB_PASS=13135690Mm@
#DB_NAME=brvm

# now use the Neon cluster
DATABASE_URL=postgresql://neondb_owner:npg_8lb9hskSXynH@ep-billowing-dust-abbl4wli-pooler.eu-west-2.aws.neon.tech:5432/brvm?sslmode=require&channel_binding=require
